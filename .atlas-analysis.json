  "keyFeatures": [
    "Browse and search prediction market events by category, tag, or keyword",
    "Place limit orders and market orders on event outcomes",
    "Support for both play money (OOM) and real money (USDC, USDT, USD)",
    "Order book with bid/ask levels for each market",
    "Price history with configurable time intervals",
    "HMAC-based authentication for secure API access",
    "Long and short positions on market outcomes",
    "Wager tracking and portfolio management"
  ],
  "publicApiSurface": [
    "GET /events/",
    "GET /events/{id}/",
    "GET /events/{id}/actions/",
    "GET /events/{id}/order_book/",
    "GET /events/{id}/price_history/",
    "GET /events/{id}/related_events/",
    "GET /events/{id}/wagers/",
    "GET /orders/",
    "POST /orders/",
    "PATCH /orders/{id}/cancel/",
    "GET /wagers/",
    "GET /wagers/{id}/",
    "GET /me/",
    "GET /me/ranking/",
    "POST /me/safe/"
  ]
}
