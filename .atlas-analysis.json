{
  "projectType": "api-service",
  "projectName": "Futuur API",
  "projectDescription": "A prediction market API that allows developers to browse events, place limit orders on outcome markets, and manage wagers using play money or real money.",
  "theme": "luma",
  "primaryColor": "#2563EB",
  "lightColor": "#EFF6FF",
  "darkColor": "#1E3A8A",
